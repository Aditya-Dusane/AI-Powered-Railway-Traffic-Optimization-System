{
  "name": "railsync-ai",
  "version": "1.0.0",
  "description": "RailSync AI - Intelligent Railway Operations Suite",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm start --prefix server\" \"npm run dev --prefix frontend\"",
    "build": "vite build --config frontend/vite.config.js",
    "start": "node server/server.js",
    "server": "npm start --prefix server",
    "client": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^4.19.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.3.1"
  }
}
